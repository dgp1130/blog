{
  "name": "publish-standard-site-documents",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "npm run -s build && node --enable-source-maps dist/index.js",
    "build": "pnpm run -s codegen && tsc",
    "codegen": "lex build --out src/gen/ --clear --indexFile",
    "test": "pnpm run -s clean && pnpm run -s build",
    "clean": "rm -rf dist/ src/gen/",
    "prepare": "lex install --ci",
    "lex": "lex"
  },
  "devDependencies": {
    "@atproto/api": "^0.20.15",
    "@atproto/lex": "^0.1.3",
    "@types/node": "^24.13.2",
    "typescript": "catalog:"
  }
}
